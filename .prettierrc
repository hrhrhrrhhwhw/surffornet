{
    "endOfLine": "lf",
    "semi": false,
    "singleQuote": true,
    "tabWidth": 4,
    "trailingComma": "es5",
    "printWidth": 120,
    "plugins": ["prettier-plugin-tailwindcss"],
    "tailwindStylesheet": "app/globals.css",
    "tailwindFunctions": ["cn", "cva"],
    "arrowParens": "always",
    "bracketSameLine": true,
    "bracketSpacing": true,
    "singleAttributePerLine": false
}
